import os
import shutil
import numpy as np
import matplotlib.pyplot as plt
from scipy.fft import fft2, ifft2, fftshift
from google.colab import files

# Enforce strictly 64-bit precision
np.set_printoptions(precision=16)

FIG_DIR = 'paper4_section5_figures'
os.makedirs(FIG_DIR, exist_ok=True)

def save_fig(fig, filename):
    filepath = os.path.join(FIG_DIR, filename)
    fig.savefig(filepath, dpi=300, bbox_inches='tight')
    print(f"Saved: {filepath}")

def plot_frequency_prior():
    fig, axes = plt.subplots(1, 3, figsize=(18, 6))
    
    # 1. Generate a Base Image with Periodic Texture (e.g., woven fabric or brick)
    N = 256
    x = np.linspace(0, 4*np.pi, N)
    y = np.linspace(0, 4*np.pi, N)
    X, Y = np.meshgrid(x, y)
    
    # Create a complex periodic structure + low frequency background
    true_signal = np.sin(5*X) * np.cos(5*Y) * 50  # High freq texture
    true_signal += np.exp(-((X-6)**2 + (Y-6)**2)/10) * 100 # Low freq blob
    true_signal += 100 # Base luminance
    true_signal = np.clip(true_signal, 0, 255)
    
    # Add severe AWGN
    sigma_eta = 40
    np.random.seed(42)
    noise = np.random.normal(0, sigma_eta, (N, N))
    noisy_obs = np.clip(true_signal + noise, 0, 255)
    
    # 2. Compute 2D FFT and Power Spectral Density (PSD)
    F_noisy = fft2(noisy_obs)
    F_noisy_shifted = fftshift(F_noisy)
    
    # Calculate PSD magnitude (Log scale for visual clarity)
    PSD = (np.abs(F_noisy_shifted)**2) / (N * N)
    PSD_log = np.log10(PSD + 1e-8)
    
    # 3. Formulate the Frequency Prior (C_3) via Spectral Modulation
    # Estimate noise floor variance in the frequency domain
    noise_power = (sigma_eta**2) * (N * N) 
    
    # Modulation envelope (Eq. 10)
    W = np.maximum(0, (PSD - noise_power) / (PSD + 1e-8))
    
    # Apply modulation and IFFT
    F_filtered_shifted = F_noisy_shifted * W
    F_filtered = fftshift(F_filtered_shifted)
    C_3 = np.real(ifft2(F_filtered))
    C_3 = np.clip(C_3, 0, 255)
    
    # --- PLOTTING ---
    # Plot 1: Noisy Observation
    im1 = axes[0].imshow(noisy_obs, cmap='gray', vmin=0, vmax=255)
    axes[0].set_title("(a) Noisy Observation ($C_1$)\nPeriodic Texture + AWGN", fontweight='bold', fontsize=14)
    axes[0].axis('off')
    
    # Plot 2: 2D Power Spectral Density
    im2 = axes[1].imshow(PSD_log, cmap='magma')
    axes[1].set_title("(b) 2D Power Spectral Density (Log Scale)\n$S_{yy}(u, v)$", fontweight='bold', fontsize=14)
    axes[1].axis('off')
    
    # Annotate the dominant harmonic spikes in the frequency domain
    center = N // 2
    axes[1].annotate('Structural\nHarmonics', xy=(center + 20, center + 20), xytext=(center + 50, center + 50),
                     arrowprops=dict(facecolor='white', shrink=0.05, width=1.5, headwidth=8),
                     fontsize=12, fontweight='bold', color='white', ha='center')
                     
    # Plot 3: The Recovered C_3 Agent
    im3 = axes[2].imshow(C_3, cmap='gray', vmin=0, vmax=255)
    axes[2].set_title("(c) Global Frequency Prior ($C_3$)\nRecovered via Spectral Modulation", fontweight='bold', fontsize=14)
    axes[2].axis('off')
    
    plt.tight_layout()
    save_fig(fig, "fig_frequency_prior.png")
    plt.close()

# Execute generator
plot_frequency_prior()

# Compress and ready for download
zip_filename = "Paper4_Section5_Figures"
shutil.make_archive(zip_filename, 'zip', FIG_DIR)
files.download(f"{zip_filename}.zip")
